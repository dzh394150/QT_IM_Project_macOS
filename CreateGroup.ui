            <property name="styleSheet">
             <string notr="true">#btncreategroup {
    /* ① 彻底隐藏边框（包括默认的焦点边框） */
    border: none !important;
    outline: none !important;
    
    /* ② 圆角矩形（12px微信输入框常用圆角，保留原有设计） */
