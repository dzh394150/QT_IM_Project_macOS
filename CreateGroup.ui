            <item>
             <widget class="QListView" name="creategroupList">
              <property name="styleSheet">
               <string notr="true">/* 滚动条整体：7px宽+全0边距 */
QListView#creategroupList QScrollBar:vertical {
    width: 7px;
    background: transparent;
    margin: 0px !important;  /* 强制全0 */
    padding: 0px !important; /* 强制全0 */
}

/* 滑槽：全0边距+3px圆角 */
QListView#creategroupList QScrollBar::groove:vertical {
    background: transparent;
    border-radius: 3px;
    margin: 0px !important;
    padding: 0px !important;
}

/* 滑块：核心！全0边距+3px圆角+无挤压 */
QListView#creategroupList QScrollBar::handle:vertical {
    background: #C8C8C8;
    border-radius: 3px;      /* 7px宽用3px圆角，Qt渲染最兼容 */
    margin: 0px !important;  /* 彻底取消所有边距，避免挤压 */
    padding: 0px !important;
    min-height: 30px;        /* 最小高度足够，保证圆角显示 */
}

/* 滑块hover状态 */
QListView#creategroupList QScrollBar::handle:vertical:hover {
    background: #A8A8A8;
}

/* 滑块按下状态 */
QListView#creategroupList QScrollBar::handle:vertical:pressed {
    background: #888888;
}

/* 隐藏箭头：全0边距 */
QListView#creategroupList QScrollBar::sub-line:vertical,
QListView#creategroupList QScrollBar::add-line:vertical {
    height: 0px;
    width: 0px;
    margin: 0px;
    padding: 0px;
}

QListView#creategroupList QScrollBar::up-arrow:vertical,
QListView#creategroupList QScrollBar::down-arrow:vertical {
    image: none;
}

QListView#creategroupList QScrollBar::corner:vertical {
    background: transparent;
    margin: 0px;
    padding: 0px;
}

#creategroupList {
    /* 1. 彻底无边框（核心需求） */
    border: none !important;          /* 去掉列表原生边框 */
    outline: none !important;         /* 去掉焦点高亮框 */
    
    /* 2. 微信风格背景色 */
    background-color: #FFFFFF !important; /* 和微信消息列表背景一致 */
    
    /* 3. 列表项间距（可选，模拟微信列表项间距） */
    spacing: 2px !important;
}

/* 美化滚动条（微信窄滚动条，可选但推荐） */
#creategroupList QScrollBar:vertical {
    background: transparent !important; /* 滚动条背景透明 */
    width: 6px !important;              /* 窄滚动条，贴合微信 */
}
#creategroupList QScrollBar::handle:vertical {
    background-color: #D1D1D1 !important; /* 滚动条滑块颜色 */
    border-radius: 3px !important;        /* 滑块圆角 */
}
#creategroupList QScrollBar::handle:vertical:hover {
    background-color: #BFBFBF !important; /* 鼠标悬浮滑块加深 */
}
#creategroupList QScrollBar::add-page:vertical,
#creategroupList QScrollBar::sub-page:vertical {
    background: transparent !important; /* 滚动条空白区域透明 */
}

/* ============================================== */
/* 新增：隐藏横向滚动条（仅保留垂直滚动条，核心需求） */
/* ============================================== */
/* 1. 横向滚动条整体隐藏：高度设为0，彻底不显示 */
#creategroupList QScrollBar:horizontal {
    height: 0px !important;           /* 横向滚动条高度设为0，隐藏本体 */
    background: transparent !important; /* 背景透明，无残留 */
    margin: 0px !important;           /* 强制边距为0，无多余空白 */
    padding: 0px !important;          /* 强制内边距为0，无多余空白 */
}

/* 2. 横向滚动条滑块隐藏：尺寸设为0，无残留 */
#creategroupList QScrollBar::handle:horizontal {
    width: 0px !important;            /* 滑块宽度设为0，隐藏滑块 */
    height: 0px !important;           /* 滑块高度设为0，隐藏滑块 */
    background: transparent !important; /* 背景透明，无残留 */
}

/* 3. 横向滚动条空白区域透明：无多余底色 */
#creategroupList QScrollBar::add-page:horizontal,
#creategroupList QScrollBar::sub-page:horizontal {
    background: transparent !important;
}

/* 4. 横向滚动条箭头隐藏：彻底消除残留元素 */
#creategroupList QScrollBar::sub-line:horizontal,
#creategroupList QScrollBar::add-line:horizontal {
    width: 0px !important;
    height: 0px !important;
}

#creategroupList QScrollBar::left-arrow:horizontal,
#creategroupList QScrollBar::right-arrow:horizontal {
    image: none !important;
}
</string>
