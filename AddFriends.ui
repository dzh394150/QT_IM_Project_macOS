         </property>
         <property name="styleSheet">
          <string notr="true">#SearchFriend {
    /* ① 彻底隐藏边框（包括默认的焦点边框） */
    border: none !important;
    outline: none !important;
    
    /* ② 圆角矩形（12px微信输入框常用圆角，保留原有设计） */
    border-radius: 12px !important;
    
    /* 常态：微信经典发送按钮绿（核心色 #07C160） */
    background-color: #07C160 !important;
    
    /* 字体颜色设为纯白色，与绿色背景对比清晰 */
    color: #FFFFFF !important;
    
    /* 优化：内边距，避免文字贴圆角边缘（保留原有优化） */
    padding: 6px 12px !important;
}

/* 鼠标悬浮：微信绿深一级（#06B058），视觉反馈自然 */
#SearchFriend:hover {
    background-color: #06B058 !important;
}

/* 鼠标按下：微信绿最深级（#059E4E），模拟按压下沉质感 */
#SearchFriend:pressed {
    background-color: #059E4E !important;
}</string>
