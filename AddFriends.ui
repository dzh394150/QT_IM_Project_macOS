        <property name="styleSheet">
         <string notr="true">#widget_2 {
    background-color: #FFFFFF !important;
    visibility: visible !important;
    opacity: 1 !important;
    border: none !important;

    /* QT全版本兼容的左右阴影（单阴影写法，无语法错误） */
