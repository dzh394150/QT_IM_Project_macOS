         <property name="styleSheet">
          <string notr="true">#AddthisFriend {
    /* 基础样式：微信原生发送按钮深绿 + 保留原有配置 */
    border: none !important;                /* 彻底隐藏边框 */
    border-radius: 4px !important;          /* 四角圆角（匹配微信按钮圆角） */
    background-color: #F0F0F0 !important;   /* 常态：微信经典发送按钮绿（核心色） */
    outline: none !important;               /* 去掉焦点框 */

}

/* 鼠标悬浮：比#F0F0F0稍深的灰色（#EBEBEB，过渡自然） */
#AddthisFriend:hover {
    background-color: #DCDCDC !important;
}

/* 鼠标按下：更深一点的灰色（#DCDCDC，质感沉稳） */
#AddthisFriend:pressed {
    background-color: #CCCCCC !important;
}</string>
