              </property>
              <property name="styleSheet">
               <string notr="true">#close_botton {
    /* 基础样式：无边框 + 四角圆角 + 透明背景 */
    border: none !important;                /* 彻底隐藏边框 */

    background: transparent !important;     /* 初始透明 */
    /* 右上角圆角8px（保持原始值，不×5） */
    border-top-right-radius: 8px !important;

    outline: none !important;               /* 去掉焦点框（QT默认点击后会有） */
}


/* 鼠标悬浮：浅一号的玫瑰红 */
#close_botton:hover {
    background-color: #E02041 !important; /* 悬浮浅玫瑰红，比默认色淡 */
	color: #FFFFFF !important; /* 悬浮时字体白色 */
}

/* 鼠标按下：颜色变深（深一号的玫瑰红） */
#close_botton:pressed {
    background-color: #C01838 !important; /* 按下深玫瑰红，比默认色深 */
	color: #FFFFFF !important; /* 悬浮时字体白色 */
}</string>
