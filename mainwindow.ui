           </property>
           <property name="styleSheet">
            <string notr="true">#btnCreateGroup {
    /* 基础样式：无边框 + 四角圆角 + 透明背景 */
    border: none !important;                /* 彻底隐藏边框 */
    border-radius: 8px !important;          /* 四角圆角（值可按需调整，如6px/10px） */
    background-color: #F0F0F0 !important;
    outline: none !important;               /* 去掉焦点框（QT默认点击后会有） */
    /* 新增：设置字体颜色（#666666是比#F0F0F0深得多的灰色，可读性佳） */
    color: #AAAAAA !important;
}

/* 鼠标悬浮：比#F0F0F0稍深的灰色，字体颜色保持不变 */
#btnCreateGroup:hover {
    background-color: #DCDCDC !important;
    /* 显式继承/保留相同字体颜色，防止被其他样式覆盖 */
    color: #AAAAAA !important;
}

/* 鼠标按下：更深一点的灰色，字体颜色保持不变 */
#btnCreateGroup:pressed {
    background-color: #CCCCCC !important;
    /* 显式继承/保留相同字体颜色，防止被其他样式覆盖 */
    color: #AAAAAA !important;
}</string>
