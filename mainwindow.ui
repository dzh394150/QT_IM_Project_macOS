              <item>
               <widget class="QProgressBar" name="fileprogress">
                <property name="styleSheet">
                 <string notr="true">/* 正确：#fileprogress 匹配objectName为fileprogress的控件（整体样式） */
#fileprogress {
    border: 1px solid #E0E0E0; /* 进度条边框（灰色，可自定义） */
    border-radius: 8px; /* 进度条圆角（可选，更美观） */
    background-color: #F5F5F5; /* 进度条未填充背景色（浅灰） */
    text-align: center; /* 进度文字居中（可选） */
}

/* 正确：#fileprogress::chunk 匹配该控件的已填充进度块（核心颜色） */
#fileprogress::chunk {
    background-color: rgb(154, 242, 109); /* 目标RGB颜色，完全支持 */
    border-radius: 4px; /* 进度块圆角（和整体进度条对应，可选） */
}</string>
