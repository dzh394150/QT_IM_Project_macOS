         <widget class="QPushButton" name="userAvatar">
          <property name="enabled">
           <bool>true</bool>
          </property>
          <property name="geometry">
           <rect>
            <x>10</x>
            <y>20</y>
            <width>40</width>
            <height>40</height>
           </rect>
          </property>
          <property name="styleSheet">
           <string notr="true">#userAvatar {
    /* 基础样式：无边框 + 四角圆角 + 透明背景 */
    border: none !important;                /* 彻底隐藏边框 */
    border-radius: 8px !important;          /* 四角圆角（值可按需调整，如6px/10px） */
    background: transparent !important;     /* 初始透明 */

    outline: none !important;               /* 去掉焦点框（QT默认点击后会有） */
}

/* 鼠标悬浮：比#F0F0F0稍深的灰色（#EBEBEB，过渡自然） */
#userAvatar:hover {
    background-color: #DCDCDC !important;
}

/* 鼠标按下：更深一点的灰色（#DCDCDC，质感沉稳） */
#userAvatar:pressed {
    background-color: #CCCCCC !important;
}</string>
          </property>
          <property name="text">
           <string/>
          </property>
         </widget>
        </widget>
