              <property name="styleSheet">
               <string notr="true">#send_botton {
    /* 基础样式：微信原生发送按钮深绿 + 保留原有配置 */
    border: none !important;                /* 彻底隐藏边框 */
    border-radius: 4px !important;          /* 四角圆角（匹配微信按钮圆角） */
    background-color: #07C160 !important;   /* 常态：微信经典发送按钮绿（核心色） */
    outline: none !important;               /* 去掉焦点框 */
    color: #FFFFFF !important;              /* 字体纯白色（和微信一致） */
}

/* 鼠标悬浮：比微信常态绿稍深，视觉反馈自然 */
#send_botton:hover {
    background-color: #06B058 !important;   /* 悬浮：深一级微信绿 */
}

/* 鼠标按下：更深的绿色，模拟按压下沉的质感 */
#send_botton:pressed {
    background-color: #059E4E !important;   /* 按下：最深级微信绿 */
}</string>
