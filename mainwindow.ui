                 <string notr="true">#close_botton_2 {
    /* 基础样式：无边框 + 四角圆角 + 透明背景 */
    border: none !important;                /* 彻底隐藏边框 */

    background: transparent !important;     /* 初始透明 */
    /* 右上角圆角8px（保持原始值，不×5） */
    border-top-right-radius: 8px !important;

    outline: none !important;               /* 去掉焦点框（QT默认点击后会有） */
}

/* 鼠标悬浮：比#F0F0F0稍深的灰色（#EBEBEB，过渡自然） */
