      <property name="styleSheet">
       <string notr="true">#stackedWidget2 {
    /* 浅灰色背景（保留原有） */
    background-color: #FFFFFF !important;
    /* 仅显示上下边框，左右无边框（核心修改） */
    border-top: 0.5px solid #D6D6D6 !important;    /* 上边框：0.5px深灰实心 */
    border-bottom: 0.5px solid #D6D6D6 !important; /* 下边框：0.5px深灰实心 */
    border-left: none !important;                /* 左边框：隐藏 */
    border-right: none !important;               /* 右边框：隐藏 */
    /* 强制显示，排除隐藏/透明干扰（保留原有） */
    visibility: visible !important;
    opacity: 1 !important;
}</string>
