           <item>
            <widget class="QListView" name="person_list">
             <property name="styleSheet">
              <string notr="true">#person_list {
    /* 1. 彻底无边框（核心需求） */
    border: none !important;          /* 去掉列表原生边框 */
    outline: none !important;         /* 去掉焦点高亮框 */
    
    /* 2. 微信风格背景色 */
    background-color: #FFFFFF !important; /* 和微信消息列表背景一致 */
    
    /* 3. 列表项间距（可选，模拟微信列表项间距） */
    spacing: 2px !important;
}

/* 美化滚动条（微信窄滚动条，可选但推荐） */
#person_list QScrollBar:vertical {
    background: transparent !important; /* 滚动条背景透明 */
    width: 6px !important;              /* 窄滚动条，贴合微信 */
}
#person_list QScrollBar::handle:vertical {
    background-color: #D1D1D1 !important; /* 滚动条滑块颜色 */
    border-radius: 3px !important;        /* 滑块圆角 */
}
#person_list QScrollBar::handle:vertical:hover {
    background-color: #BFBFBF !important; /* 鼠标悬浮滑块加深 */
}
#person_list QScrollBar::add-page:vertical,
#person_list QScrollBar::sub-page:vertical {
    background: transparent !important; /* 滚动条空白区域透明 */
}</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
