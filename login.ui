         <property name="styleSheet">
          <string notr="true">#login_botton {
    /* ① 彻底隐藏边框（包括默认的焦点边框） */
    border: none !important;
    outline: none !important;
    
    /* ② 圆角矩形（12px是微信输入框常用圆角，可按需调整） */
    border-radius: 12px !important;
    
    background-color: #E02041 !important;
    /* 现代亮玫瑰红（更贴近移动端常用风格）
    background-color: #E02041 !important;
    */
    
    /* 字体颜色设为纯白色 */
    color: #FFFFFF !important;
    
    /* 优化：内边距，避免文字贴圆角边缘（可选但推荐） */
    padding: 6px 12px !important;
}

/* 鼠标悬浮：颜色变淡（浅一号的玫瑰红） */
