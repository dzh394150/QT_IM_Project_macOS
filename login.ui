        <widget class="QPushButton" name="btnRegister">
         <property name="geometry">
          <rect>
           <x>40</x>
           <y>170</y>
           <width>111</width>
           <height>18</height>
          </rect>
         </property>
         <property name="font">
          <font>
           <pointsize>12</pointsize>
          </font>
         </property>
         <property name="styleSheet">
          <string notr="true">#btnRegister {
    /* 基础样式：无边框 + 四角圆角 + 透明背景 */
    border: none !important;                /* 彻底隐藏边框 */
    border-radius: 4px !important;          /* 四角圆角（值可按需调整） */
    background: transparent !important;     /* 初始透明 */
    outline: none !important;               /* 去掉焦点框（QT默认点击后会有） */
    
    /* 新增：文字靠左 + 浅灰色 + 左内边距（避免文字贴边） */
    text-align: left !important;            /* 文字靠左对齐 */
    color: #999999 !important;              /* 浅灰色文字（可按需调整：#AAAAAA更浅 / #888888稍深） */
    padding-left: 8px !important;           /* 左内边距（可选，值可调整，如10px） */
    padding-right: 8px !important;          /* 右内边距（保持对称，可选） */
}

/* 鼠标悬浮：背景加深 + 文字颜色轻微加深（可选，增强交互） */
#btnRegister:hover {
    background-color: #DCDCDC !important;
    color: #888888 !important;              /* 悬浮时文字稍深（可删除，保持和基础色一致） */
}

/* 鼠标按下：背景更深 + 文字颜色再深一点（可选） */
#btnRegister:pressed {
    background-color: #CCCCCC !important;
    color: #777777 !important;            /* 按下时文字更深（可删除） */
}</string>
