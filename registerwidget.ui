         <property name="styleSheet">
          <string notr="true">#btnAvatar {
    /* 核心：深灰色(#999999)虚线边框（替代原浅灰#F0F0F0） */
    border: 1px dashed #999999 !important; /* 1px虚线 + 深灰色，视觉更醒目 */

    
    /* 文本颜色：同步改为深灰色#999999 */
    color: #999999 !important;
    
    /* 背景透明，适配多数场景（如需深色底可替换） */
    background-color: transparent !important;
    
    /* 内边距：避免文字贴边框，提升排版舒适度 */
    padding: 6px 12px !important;
    
    /* 清除QT默认焦点框/多余样式 */
    outline: none !important;
}

/* 鼠标悬浮：虚线+文本稍深，增强交互反馈 */
#btnSelectAvatar:hover {
    border-color: #888888 !important; /* 悬浮时深一级灰色 */
    color: #888888 !important;
    background-color: rgba(0, 0, 0, 0.03) !important; /* 轻微背景灰，不突兀 */
}

/* 鼠标按下：虚线+文本再深，模拟按压质感 */
#btnSelectAvatar:pressed {
    border-color: #777777 !important; /* 按下时最深一级灰色 */
    color: #777777 !important;
}</string>
